# Same database as dashboard (iprn_system)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=iprn_system
MYSQL_USER=asterisk
MYSQL_PASSWORD=

# Carrier API (avoid clashing with dashboard on 3000)
CARRIER_PORT=3010

# Digits to use as "prefix" key from call_logs.destination (default 3)
PREFIX_GROUP_LEN=3

# Phase 2 — Asterisk AMI (set AMI_ENABLED=0 to skip)
AMI_ENABLED=1
AMI_HOST=127.0.0.1
AMI_PORT=5038
AMI_USERNAME=carrier
AMI_PASSWORD=strongpassword

# Inbound IVR only: log calls that hit dialplan context ivr-* (Newexten + Hangup). Set 0 for all Dial/Hangup.
AMI_IVR_ONLY=1
# Optional: override context match (default ^ivr-\d+$)
# AMI_IVR_CONTEXT_REGEX=^ivr-\d+$

PORT=3010
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=iprn
MYSQL_PASSWORD=secret
MYSQL_DATABASE=iprn
MYSQL_POOL_LIMIT=32
JWT_SECRET=change-this-to-a-long-random-string
INTERNAL_API_KEY=change-this-for-asterisk-agi-internal-calls
IVR_UPLOAD_DIR=./uploads/ivr
ASTERISK_GENERATED_DIR=../asterisk-generated
ASTERISK_BIN=asterisk
# Copy generated configs to live Asterisk dir before reload (optional)
# ASTERISK_INSTALL_DIR=/etc/asterisk
# ASTERISK_USE_SUDO=1

# Config sync (outbox poller starts with API; apply sql/008_config_sync_outbox.sql)
CONFIG_SYNC_OUTBOX_POLL=1
CONFIG_SYNC_POLL_MS=2000
CONFIG_SYNC_DEBOUNCE_MS=1500
CONFIG_SYNC_RELOAD=1
# Skip asterisk -rx pre-check (generate files only)
# CONFIG_SYNC_SKIP_CLI_CHECK=1
# Optional: git repo path for committed snapshots (pjsip.generated.conf, extensions.generated.conf)
# CONFIG_SYNC_GIT_DIR=/var/lib/asterisk-config-git

# Queue sync from API after routes/suppliers/numbers mutations (also use DB triggers + poller)
AUTO_SYNC_ASTERISK=1

# AMI (optional live monitoring)
AMI_HOST=127.0.0.1
AMI_PORT=5038
AMI_USER=admin
AMI_SECRET=amp111

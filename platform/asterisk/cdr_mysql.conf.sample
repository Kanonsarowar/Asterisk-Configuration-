; cdr_mysql — legacy native MySQL CDR module (if shipped with your Asterisk build)
; Prefer cdr_adaptive_odbc + MySQL ODBC (see cdr_adaptive_odbc_mysql.conf.sample) for schema control.
;
; [global]
; hostname=127.0.0.1
; dbname=iprn
; table=cdr
; password=secret
; user=iprn
; port=3306
; charset=utf8mb4
;
; Map Asterisk fields to platform columns (names vary by version — verify with "cdr show status"):
; calldate => start_time
; clid => cli
; dst => destination
; duration => duration
; disposition => disposition
; uniqueid => uniqueid
; linkedid => call_id
;
; Rows inserted here skip API-side matching unless you run:
;   cd api && npm run finalize-cdr
; or use the AMI listener with CDR_FROM_AMI=1 / HTTP ingest (see scripts/ami-listener.js).

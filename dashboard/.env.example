# Copy to the same directory as server.js as `.env` (auto-loaded), or use systemd:
#   EnvironmentFile=/opt/asterisk-dashboard/.env
# Values here are ignored if already set in the environment (systemd overrides).

PORT=3000

# After a successful console login, copy generated configs to /etc/asterisk/ and reload (requires sudo).
# AUTO_APPLY_ASTERISK_ON_LOGIN=1

# ---- MySQL (iprn_system) — enables DID list + number_inventory sync + billing API ----
MYSQL_ENABLED=1
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=iprn_system
MYSQL_USER=asterisk
MYSQL_PASSWORD=change_me

# Optional pool size (default 10)
# MYSQL_CONNECTION_LIMIT=10

# Dashboard still uses db.json for suppliers, IVR, trunk, globals when MySQL is on;
# DID rows are read/written from table `numbers` and mirrored to `number_inventory` for Asterisk ODBC.

# ---- Optional: legacy / second IPRN web app — sidebar opens in new tab (primary control is this dashboard) ----
# IPRN_PLATFORM_URL=http://127.0.0.1:3010

# ---- Tenant call generator (client portal) — full string passed to: sudo asterisk -rx "<cmd>" ----
# Placeholders: {DEST} = called number (digits), {FROM} = selected assigned DID (digits)
# TENANT_ORIGINATE_CMD=channel originate Local/7001@from-internal application Dial PJSIP/{DEST}@your-endpoint
# Reject originate when balance <= 0 (optional)
# TENANT_ENFORCE_BALANCE=1

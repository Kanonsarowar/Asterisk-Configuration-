MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=iprn
MYSQL_PASSWORD=secret
MYSQL_DATABASE=iprn

# Where fragments are written first (then copied if ASTERISK_INSTALL_DIR set)
ASTERISK_OUTPUT_DIR=./output

# Copy generated tree here so Asterisk loads it (optional)
# ASTERISK_INSTALL_DIR=/etc/asterisk

# asterisk -rx reload (use sudo on typical installs)
# ASTERISK_USE_SUDO=1
# ASTERISK_BIN=/usr/sbin/asterisk

# Skip reload (files only)
# SKIP_ASTERISK_RELOAD=1

# PJSIP transport / NAT (optional)
# PJSIP_UDP_BIND=0.0.0.0:5060
# PJSIP_EXTERNAL_MEDIA_ADDRESS=203.0.113.1
# PJSIP_EXTERNAL_SIGNALING_ADDRESS=203.0.113.1
# PJSIP_LOCAL_NETS=10.0.0.0/8,192.168.0.0/16

# Dialplan: inbound context sends DID to route context
# DIALPLAN_INBOUND_CONTEXT=from-supplier
# DIALPLAN_ROUTE_CONTEXT=prefix-routes
# ASTERISK_OUTBOUND_CONTEXT=from-internal

# Pattern _PREFIX + suffix (default _88213X. style)
# DIALPLAN_PATTERN_SUFFIX=X.
# DIAL_TIMEOUT_SEC=30

# HTTP trigger (npm run serve)
# GENERATOR_HTTP_PORT=3020
# GENERATOR_HTTP_TOKEN=change-me

# Poll MySQL (npm run watch)
# GENERATOR_WATCH_INTERVAL_SEC=60
